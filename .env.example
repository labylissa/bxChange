# Backend (.env)
DATABASE_URL=postgresql+asyncpg://bxchange:password@db:5432/bxchange_db
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:5173"]

# Super Admin bootstrap (auto-created at startup if no super_admin exists)
SUPER_ADMIN_EMAIL=superadmin@bxchange.io
SUPER_ADMIN_PASSWORD=change_me_strong_password

# SSO / SAML Service Provider (Sprint 15)
# SP_ENTITY_ID and SP_ACS_URL identify your bxChange instance to SAML IdPs
SP_ENTITY_ID=https://app.bxchange.io
SP_ACS_URL=https://app.bxchange.io/api/v1/sso/acs
# PEM certificate and private key for signing SAML requests (no headers, single line)
# Generate with: openssl req -x509 -newkey rsa:2048 -keyout key.pem -out cert.pem -days 3650 -nodes
SP_CERTIFICATE=
SP_PRIVATE_KEY=

# WSDL upload directory (default: /app/uploads/wsdl)
# WSDL_UPLOAD_DIR=/app/uploads/wsdl

# Frontend (.env)
VITE_API_URL=http://localhost:8000
